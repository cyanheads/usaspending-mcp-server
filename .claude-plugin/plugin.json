{
  "name": "@cyanheads/usaspending-mcp-server",
  "version": "0.2.1",
  "description": "Access US federal award, recipient, agency, and spending analytics data from USAspending.gov via MCP.",
  "author": {
    "name": "cyanheads"
  },
  "homepage": "https://github.com/cyanheads/usaspending-mcp-server#readme",
  "repository": "https://github.com/cyanheads/usaspending-mcp-server",
  "license": "Apache-2.0",
  "mcpServers": {
    "@cyanheads/usaspending-mcp-server": {
      "command": "npx",
      "args": ["-y", "@cyanheads/usaspending-mcp-server"],
      "env": {
        "MCP_TRANSPORT_TYPE": "stdio"
      }
    }
  }
}
