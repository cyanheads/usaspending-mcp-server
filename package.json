{
  "name": "@cyanheads/usaspending-mcp-server",
  "mcpName": "io.github.cyanheads/usaspending-mcp-server",
  "version": "0.2.8",
  "description": "Access US federal award, recipient, agency, and spending analytics data from USAspending.gov via MCP. STDIO or Streamable HTTP.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "usaspending-mcp-server": "dist/index.js"
  },
  "files": [
    "changelog/",
    "dist/",
    "README.md",
    "LICENSE",
    "CLAUDE.md",
    "Dockerfile",
    "server.json"
  ],
  "scripts": {
    "build": "bun run scripts/build.ts",
    "rebuild": "bun run scripts/clean.ts && bun run build",
    "clean": "bun run scripts/clean.ts",
    "devcheck": "bun run scripts/devcheck.ts",
    "audit:refresh": "rm -f bun.lock && bun install && bun audit",
    "tree": "bun run scripts/tree.ts",
    "list-skills": "bun run scripts/list-skills.ts",
    "format": "biome check --write --unsafe .",
    "lint:mcp": "bun run scripts/lint-mcp.ts",
    "lint:packaging": "bun run scripts/lint-packaging.ts",
    "bundle": "bun run build && npx -y @anthropic-ai/mcpb pack . dist/usaspending-mcp-server.mcpb && bun run scripts/clean-mcpb.ts dist/usaspending-mcp-server.mcpb",
    "release:github": "bun run scripts/release-github.ts",
    "publish-mcp": "mcp-publisher login github -token \"$(security find-generic-password -a \"$USER\" -s mcp-publisher-github-pat -w)\" && mcp-publisher publish",
    "changelog:build": "bun run scripts/build-changelog.ts",
    "changelog:check": "bun run scripts/build-changelog.ts --check",
    "test": "bunx vitest run",
    "start:stdio": "MCP_TRANSPORT_TYPE=stdio bun ./dist/index.js",
    "start:http": "MCP_TRANSPORT_TYPE=http bun ./dist/index.js"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "typescript",
    "bun",
    "stdio",
    "streamable-http",
    "federal-spending",
    "usaspending",
    "government-contracts",
    "government-grants",
    "treasury",
    "federal-awards",
    "data-act",
    "government-procurement",
    "fiscal-policy"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cyanheads/usaspending-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/cyanheads/usaspending-mcp-server/issues"
  },
  "homepage": "https://github.com/cyanheads/usaspending-mcp-server#readme",
  "author": "Casey Hand <casey@caseyjhand.com> (https://caseyjhand.com)",
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/cyanheads"
    },
    {
      "type": "buy_me_a_coffee",
      "url": "https://www.buymeacoffee.com/cyanheads"
    }
  ],
  "license": "Apache-2.0",
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=24.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "trustedDependencies": ["@socketsecurity/bun-security-scanner"],
  "dependencies": {
    "@cyanheads/mcp-ts-core": "^0.10.14",
    "pino-pretty": "^13.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@socketsecurity/bun-security-scanner": "^1.1.2",
    "@types/node": "^26.0.0",
    "depcheck": "^1.4.7",
    "ignore": "^7.0.5",
    "tsc-alias": "^1.8.17",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
